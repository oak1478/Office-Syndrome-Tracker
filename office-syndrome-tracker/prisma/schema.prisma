generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  name      String?
  user      String   @unique  // ต้องใช้คำว่า user ให้ตรงกับในโค้ด
  email     String   @unique  // ต้องมีฟิลด์ email เพิ่มเข้ามา
  password  String
  jobTitle  String?
  role      String   @default("USER") // เพิ่มฟิลด์สิทธิ์การใช้งาน ค่าเริ่มต้นคือผู้ใช้ทั่วไป
  records   HealthRecord[]
}

model HealthRecord {
  id              String   @id @default(cuid())
  date            DateTime @default(now())
  updatedAt       DateTime @updatedAt @default(now())
  // รายการอาการทางกายภาพ
  neckPain        Boolean  @default(false)
  backPain        Boolean  @default(false)
  eyeStrain       Boolean  @default(false)
  wristPain       Boolean  @default(false)
  headache        Boolean  @default(false)
  fingerNumbness  Boolean  @default(false)
  legNumbness     Boolean  @default(false)

  // พฤติกรรมการทำงาน
  tookBreaks      Boolean  @default(false)

  // ระดับความเหนื่อยล้า
  stressLevel     Int      @default(1)

  // บันทึกเพิ่มเติม
  note            String?

  // การเชื่อมโยงข้อมูลผู้ใช้งาน
  authorId        String
  author          User     @relation(fields: [authorId], references: [id])
}